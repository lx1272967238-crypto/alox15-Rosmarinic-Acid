# 1. 通用工具函数
import pandas as pd, numpy as np, matplotlib.pyplot as plt, seaborn as sns, joblib, warnings, torch, torch.nn as nn, torch.optim as optim
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier, GradientBoostingClassifier, ExtraTreesClassifier, VotingClassifier
from sklearn.metrics import (roc_curve, auc, precision_recall_curve, f1_score,
                             RocCurveDisplay, PrecisionRecallDisplay)
from rdkit import Chem
from rdkit.Chem import Descriptors
from sklearn.ensemble import (RandomForestClassifier, BaggingClassifier,
                              HistGradientBoostingClassifier)
from lightgbm import LGBMClassifier
warnings.filterwarnings("ignore")

#2. 数据读取 + 描述符 + 二值化
def calc_desc(smiles):
    if not isinstance(smiles, str) or not smiles.strip():
        return None
    mol = Chem.MolFromSmiles(smiles.strip())
    if mol is None: return None
    return {n: f(mol) for n, f in Descriptors.descList}

df = pd.read_csv('/content/CHEMBL2903_.csv')
df = df[df['Smiles'].notna()]
df['Smiles'] = df['Smiles'].astype(str).str.strip()
df = df[df['Smiles'] != '']
desc = df['Smiles'].apply(calc_desc)
df = pd.concat([df, desc.apply(pd.Series)], axis=1).dropna(subset=desc.apply(pd.Series).columns)
X = df.drop(['Smiles', 'PIC50'], axis=1)
y = (df['PIC50'] >= 5.2).astype(int)          # 二值化
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42, stratify=y)


#4 个单独的分类器
models = {
    'RandomForest': RandomForestClassifier(n_estimators=1000, random_state=42, n_jobs=-1),
    'Bagging':      BaggingClassifier(n_estimators=1000, random_state=42, n_jobs=-1),
    'HistGB':       HistGradientBoostingClassifier(max_iter=1000, random_state=42),
    'LGBM':         LGBMClassifier(n_estimators=1000, random_state=42, n_jobs=-1, verbose=-1)
}

# 统一训练
for name, mdl in models.items():
    mdl.fit(X_train, y_train)
for name, mdl in models.items():
    mdl.fit(X_train, y_train)



# 5. 统一打分 & 画图
# ── 1. ROC 曲线（单独） ──────────────────────────────────────
plt.figure(figsize=(6, 6),dpi=300)
plt.plot([0, 1], [0, 1], 'k--', alpha=.5)
for nm, mdl in models.items():
    sc = mdl.predict_proba(X_test)[:, 1]
    fpr, tpr, _ = roc_curve(y_test, sc)
    roc_auc = auc(fpr, tpr)
    plt.plot(fpr, tpr, lw=2, label=f'{nm} (AUC={roc_auc:.3f})')

plt.xlabel('FPR'); plt.ylabel('TPR')
plt.title('ROC')
plt.legend()
plt.tight_layout()
plt.show()
# ── 2. PR 曲线（单独） ──────────────────────────────────────
plt.figure(figsize=(6, 6),dpi=300)
baseline = y_test.mean()
plt.axhline(y=baseline, color='k', linestyle='--', alpha=.5)
for nm, mdl in models.items():
    sc = mdl.predict_proba(X_test)[:, 1]
    prec, rec, _ = precision_recall_curve(y_test, sc)
    pr_auc = auc(rec, prec)
    f1 = f1_score(y_test, (sc >= 0.5).astype(int))
    plt.plot(rec, prec, lw=2, label=f'{nm} (AP={pr_auc:.3f}, F1={f1:.3f})')

plt.xlabel('Recall'); plt.ylabel('Precision')
plt.title('PR curve')
plt.legend(loc='lower left')
plt.tight_layout()
plt.show()
!pip install rdkit joblib -q
import numpy as np
import pandas as pd
from rdkit import Chem
from rdkit.Chem import AllChem
import joblib

# 1. 加载模型 & 预处理
model = joblib.load('lgbm_model.pkl')
prep  = joblib.load('preprocessing_info.pkl')

# 2. SMILES → ECFP6 (4096-bit)
def smiles_to_ecfp6(smiles, radius=3, nBits=4096):
    mol = Chem.MolFromSmiles(smiles)
    if mol is None:
        return None
    fp = AllChem.GetMorganFingerprintAsBitVect(mol, radius=radius, nBits=nBits)
    arr = np.zeros((1,), dtype=np.int8)
    AllChem.DataStructs.ConvertToNumpyArray(fp, arr)
    return arr

# 3. 单条预测
def predict_PIC50(smiles):
    arr = smiles_to_ecfp6(smiles)
    if arr is None:
        return np.nan
    arr_sel = prep['variance_selector'].transform(arr.reshape(1, -1))
    return float(model.predict(arr_sel)[0])

# 4. 批量读文件
df = pd.read_csv('/content/天然酚类化合物库.csv')          # 自动识别列名（不区分大小写）
smiles_col = next(c for c in df.columns if c.lower() == 'smiles')

# ↓↓↓ 新增：清洗非字符串/空值 ↓↓↓
df[smiles_col] = df[smiles_col].astype(str).str.strip().replace('nan', np.nan)
df = df.dropna(subset=[smiles_col])          # 可选：直接丢掉空 SMILES

print('正在预测 …')
df['PIC50_pred'] = df[smiles_col].apply(predict_PIC50)

# 5. 保存
out_file = '/content/天然酚类化合物库_PIC50.csv'
df.to_csv(out_file, index=False)
print(f'完成！结果已写入 {out_file}')
print("\n所有结果已保存完毕！")
