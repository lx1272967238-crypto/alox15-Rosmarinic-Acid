import pandas as pd
import numpy as np
from rdkit import Chem
from rdkit.Chem import Descriptors
from sklearn.model_selection import train_test_split
from sklearn.feature_selection import VarianceThreshold
from lazypredict.Supervised import LazyRegressor
import matplotlib.pyplot as plt
import seaborn as sns
from rdkit.Chem import GraphDescriptors

# 自定义函数：计算分子描述符
from rdkit.Chem import AllChem   # 新增

def calculate_descriptors(smiles):
    """
    用 ECFP6（半径=3，4096bit）代替传统描述符
    返回 4096 列的 dict，列名 F0,F1,…,F1023
    """
    if not isinstance(smiles, str) or not smiles.strip():
        return {f'F{i}': None for i in range(4096)}

    mol = Chem.MolFromSmiles(smiles.strip())
    if mol is None:
        return {f'F{i}': None for i in range(4096)}

    # 1. 生成二进制指纹
    fp = AllChem.GetMorganFingerprintAsBitVect(mol, radius=3, nBits=4096)
    # 2. 转成 0/1 列表
    arr = np.asarray(fp, dtype=np.uint8)   # shape (1024,)
    # 3. 转成 dict → 后续 pd.Series 自动对齐
    return {f'F{i}': int(arr[i]) for i in range(4096)}
# =========================================================
# ==================================================
# 1. 数据加载与预处理
print("正在加载数据...")
df = pd.read_csv("/content/CHEMBL2903_.csv")

# 2. 计算分子描述符
print("正在计算分子描述符...")
descriptors = df['Smiles'].apply(calculate_descriptors)
df = pd.concat([df, descriptors.apply(pd.Series)], axis=1)

# 3. 数据清洗
print("\n数据清洗：")
# 删除无效的SMILES
initial_count = len(df)
df = df.dropna(subset=descriptors.apply(pd.Series).columns)
print(f"删除无效SMILES记录：{initial_count - len(df)}条")

# 处理其他缺失值（用均值填充）
numeric_cols = df.select_dtypes(include=np.number).columns
df[numeric_cols] = df[numeric_cols].fillna(df[numeric_cols].mean())

# 4. 准备特征矩阵和标签
X = df.drop(['Smiles', 'PIC50'], axis=1)
y = df['PIC50']

# 检查特征矩阵数据类型
if not all([np.issubdtype(dtype, np.number) for dtype in X.dtypes]):
    raise ValueError("特征矩阵包含非数值型列")

# 5. 特征选择
print("\n特征选择：")
threshold = 0.8 * (1 - 0.8)
selection = VarianceThreshold(threshold=threshold)
X_selected = selection.fit_transform(X)
selected_features = X.columns[selection.get_support(indices=True)]
X = pd.DataFrame(X_selected, columns=selected_features)
print(f"保留特征数量：{X.shape[1]}")

# 6. 拆分数据集
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42
)
print(f"\n训练集大小：{X_train.shape[0]} 样本")
print(f"测试集大小：{X_test.shape[0]} 样本")

# 7. 初始化并运行LazyRegressor
print("\n正在训练和评估模型...")
reg = LazyRegressor(verbose=0, ignore_warnings=True, custom_metric=None)
models, predictions = reg.fit(X_train, X_test, y_train, y_test)

# 8. 结果展示
print("\n回归模型性能对比（测试集）：")
display(models[['RMSE', 'R-Squared', 'Time Taken']])

# 9. 可视化结果（仅展示前40模型）
plt.figure(figsize=(12, 6),dpi=1200, facecolor='white')

# 设置全局样式
sns.set_style("white")

# 筛选前30模型数据
top_rmse = models.sort_values('RMSE').head(30)        # RMSE升序排列取最小前30
top_r2 = models.sort_values('R-Squared', ascending=False).head(30)  # R²降序排列取最大前30
top_time = models.sort_values('Time Taken').head(30)  # 时间升序排列取最快前30

# ── 1. RMSE 图（单独） ─────────────────────────────────────────
plt.figure(figsize=(6, 6),dpi=300)
palette = sns.color_palette('Blues_r', n_colors=30)
colors = [palette[i] for i in range(len(top_rmse))]
sns.barplot(y=top_rmse.index, x='RMSE', data=top_rmse,
            palette=colors, edgecolor='black')
plt.title('Top 30 Models by RMSE', fontsize=14)
plt.xlabel('RMSE', fontsize=12)
plt.ylabel('Model', fontsize=12)
plt.gca().set_facecolor('white')
plt.grid(False)
plt.tight_layout()
plt.show()

# ── 2. R² 图（单独） ─────────────────────────────────────────
plt.figure(figsize=(6, 6),dpi=300)
palette = sns.color_palette('Greens_r', n_colors=30)
colors = [palette[i] for i in range(len(top_r2))]
sns.barplot(y=top_r2.index, x='R-Squared', data=top_r2,
            palette=colors, edgecolor='black')
plt.title('Top 30 Models by R-Squared', fontsize=14)
plt.xlabel('R-Squared', fontsize=12)
plt.ylabel('Model', fontsize=12)
plt.gca().set_facecolor('white')
plt.grid(False)
plt.tight_layout()
plt.show()



# 调整布局并显示
plt.tight_layout()
sns.despine()
plt.show()
# 9. 可视化结果（仅展示前40模型）
plt.figure(figsize=(24, 12),dpi=1200, facecolor='white')

# 设置全局样式
sns.set_style("white")

# 筛选前30模型数据
top_rmse = models.sort_values('RMSE').head(30)        # RMSE升序排列取最小前30
top_r2 = models.sort_values('R-Squared', ascending=False).head(30)  # R²降序排列取最大前30
top_time = models.sort_values('Time Taken').head(30)  # 时间升序排列取最快前30

# RMSE对比
plt.subplot(1, 2, 1)
sns.barplot(y=top_rmse.index, x='RMSE', data=top_rmse,
            color='#90BEE0', edgecolor='black')
plt.title('Top 30 Models by RMSE', fontsize=14)
plt.xlabel('RMSE', fontsize=12)
plt.ylabel('Model', fontsize=12)
plt.gca().set_facecolor('white')
plt.grid(False)

# R²对比
plt.subplot(1, 2, 2)
sns.barplot(y=top_r2.index, x='R-Squared',
            data=top_r2,
            color='#90BEE0', edgecolor='black')
plt.title('Top 30 Models by R-Squared', fontsize=14)
plt.xlabel('R-Squared', fontsize=12)
plt.xlim(0, 1)
plt.gca().set_facecolor('white')
plt.grid(False)

# 训练时间对比
plt.subplot(1, 3, 3)
sns.barplot(y=top_time.index, x='Time Taken',
            data=top_time,
            color='#90BEE0', edgecolor='black')
plt.title('Top 30 Models by Training Time', fontsize=14)
plt.xlabel('Time Taken (seconds)', fontsize=12)
plt.gca().set_facecolor('white')
plt.grid(False)

# 调整布局并显示
plt.tight_layout()
sns.despine()
plt.show()
