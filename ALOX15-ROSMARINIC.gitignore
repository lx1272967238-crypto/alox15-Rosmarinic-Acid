import pandas as pd
import numpy as np
import joblib  # 新增导入
from rdkit import Chem
from rdkit.Chem import Descriptors
from sklearn.model_selection import train_test_split
from sklearn.feature_selection import VarianceThreshold
from sklearn.metrics import mean_squared_error, r2_score
import matplotlib.pyplot as plt
import seaborn as sns
from lightgbm import LGBMRegressor
from scipy.stats import linregress
from rdkit.Chem import AllChem
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_squared_error

# ---------- 1. 计算 ECFP6 4096bit ----------
def calculate_descriptors(smiles):
    """ECFP6, 4096bit"""
    if not isinstance(smiles, str) or not smiles.strip():
        return {f'F{i}': None for i in range(4096)}
    mol = Chem.MolFromSmiles(smiles.strip())
    if mol is None:
        return {f'F{i}': None for i in range(4096)}
    fp = AllChem.GetMorganFingerprintAsBitVect(mol, radius=3, nBits=4096)
    arr = np.asarray(fp, dtype=np.uint8)
    return {f'F{i}': int(arr[i]) for i in range(4096)}



# 1. 数据加载与预处理
print("正在加载数据...")
df = pd.read_csv("/content/CHEMBL2903_.csv")

# 2. 计算分子描述符
print("正在计算分子描述符...")
descriptors = df['Smiles'].apply(calculate_descriptors)
df = pd.concat([df, descriptors.apply(pd.Series)], axis=1)

# 3. 数据清洗
print("\n数据清洗：")
initial_count = len(df)
df = df.dropna(subset=descriptors.apply(pd.Series).columns)
print(f"删除无效SMILES记录：{initial_count - len(df)}条")

# 处理其他缺失值
numeric_cols = df.select_dtypes(include=np.number).columns
df[numeric_cols] = df[numeric_cols].fillna(df[numeric_cols].mean())

# 4. 准备特征矩阵和标签
X = df.drop(['Smiles', 'PIC50'], axis=1)
y = df['PIC50']

# 检查特征矩阵数据类型
if not all([np.issubdtype(dtype, np.number) for dtype in X.dtypes]):
    raise ValueError("特征矩阵包含非数值型列")

# 5. 特征选择
print("\n特征选择：")
threshold = 0.8 * (1 - 0.8)
selection = VarianceThreshold(threshold=threshold)
X_selected = selection.fit_transform(X)
selected_features = X.columns[selection.get_support(indices=True)]
X = pd.DataFrame(X_selected, columns=selected_features)
print(f"保留特征数量：{X.shape[1]}")

# 6. 拆分数据集
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42
)
print(f"\n训练集大小：{X_train.shape[0]} 样本")
print(f"测试集大小：{X_test.shape[0]} 样本")

# 7. 训练随机森林模型（修改部分）
print("\n训练 RandomForest 回归模型...")
model = RandomForestRegressor(
    n_estimators=1000,   # 与原来 LGBM 保持一致
    random_state=42,
    n_jobs=-1
)
# 随机森林不需要 eval_set，直接 fit
model.fit(X_train, y_train)

# l新增：绘制训练损失曲线
pt.figure(figsize=(6, 6), dpi=300, facecolor='white')
sns.set_style("whitegrid")

LOSS_COLOR = (217/255, 65/255, 43/255)  # 指定RGB颜色





# 保存模型和预处理信息
print("\n保存模型和预处理信息...")
joblib.dump(model, 'lgbm_model.pkl')

# ✅ 只保留真正会用到的字段
preprocessing_info = {
    'variance_selector': selection,
    'selected_features': selected_features.tolist()
}
joblib.dump(preprocessing_info, 'preprocessing_info.pkl')

# 8. 模型评估
y_pred = model.predict(X_test)
rmse = np.sqrt(mean_squared_error(y_test, y_pred))
r2 = r2_score(y_test, y_pred)

print(f"\n模型性能评估：")
print(f"RMSE: {rmse:.4f}")
print(f"R²: {r2:.4f}")

# 9. 可视化预测结果（修改部分）
min_val = min(y_test.min(), y_pred.min())  # 添加缺失变量定义
max_val = max(y_test.max(), y_pred.max())  # 添加缺失变量定义

plt.figure(figsize=(8, 6), dpi=100, facecolor='white')  # 修改dpi为600
sns.set_style("whitegrid")

# 颜色配置
DATA_COLOR = (75/255, 116/255, 178/255)
REGRESSION_COLOR = (219/255, 49/255, 36/255)
PERFECT_COLOR = (144/255, 190/255, 224/255)

# 计算回归线参数
slope, intercept, r_value, _, _ = linregress(y_test, y_pred)
reg_line = slope * y_test + intercept

# 绘制散点图
ax = sns.scatterplot(
    x=y_test,
    y=y_pred,
    color=DATA_COLOR,
    alpha=0.9,
    edgecolor='w',
    linewidth=0.3,
    label='Predictions'
)

# 添加参考线
plt.plot(y_test, reg_line, color=PERFECT_COLOR, lw=2.0, label='Regression line')
plt.plot([min_val, max_val], [min_val, max_val], '--',
         color=REGRESSION_COLOR, lw=2.0, label='Perfect fit')

# 图形美化
plt.title('Prediction Performance Visualization', fontsize=14, pad=20)
plt.xlabel('True PIC50 Values', fontsize=12)
plt.ylabel('Predicted PIC50 Values', fontsize=12)
plt.grid(True, linestyle=':', alpha=0.9)

# 指标标注
text_str = f'RMSE = {rmse:.3f}\nR² = {r2:.3f}\nSlope = {slope:.3f}'
plt.text(
    x=0.05, y=0.95,
    s=text_str,
    transform=ax.transAxes,
    verticalalignment='top',
    fontsize=10,
    bbox=dict(
        facecolor='#f8f8f8',
        alpha=0.9,
        edgecolor='#d0d0d0',
        boxstyle='round,pad=0.3'
    )
)

# 坐标轴调整
buffer_range = (max_val - min_val) * 0.07
ax.set_xlim(min_val - buffer_range, max_val + buffer_range)
ax.set_ylim(min_val - buffer_range, max_val + buffer_range)

# 设置刻度格式
ax.xaxis.set_major_formatter(plt.FormatStrFormatter('%.1f'))
ax.yaxis.set_major_formatter(plt.FormatStrFormatter('%.1f'))

plt.tight_layout()
plt.show()
