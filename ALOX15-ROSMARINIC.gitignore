import pandas as pd
import numpy as np
import joblib
from rdkit import Chem
from rdkit.Chem import Descriptors
from sklearn.model_selection import train_test_split, KFold, cross_val_score
from sklearn.feature_selection import VarianceThreshold
from sklearn.metrics import mean_squared_error, r2_score
import matplotlib.pyplot as plt
import seaborn as sns
from lightgbm import LGBMRegressor
from scipy.stats import linregress
import optuna
import warnings
warnings.filterwarnings('ignore')

# 定义颜色方案
colors = {
    'red': (219/255, 49/255, 36/255),
    'orange': (252/255, 140/255, 90/255),
    'yellow': (255/255, 223/255, 146/255),
    'light_blue': (230/255, 241/255, 243/255),
    'blue': (144/255, 190/255, 224/255),
    'dark_blue': (75/255, 116/255, 178/255)
}

# 设置全局绘图样式
sns.set_style("whitegrid")
sns.set_palette([colors['blue'], colors['dark_blue'], colors['light_blue'],
                colors['orange'], colors['yellow'], colors['red']])
plt.rcParams['axes.facecolor'] = 'white'
plt.rcParams['figure.facecolor'] = 'white'
plt.rcParams['grid.color'] = '#DDDDDD'
plt.rcParams['grid.alpha'] = 0.5

# 自定义函数：计算分子描述符
# ---------- 1. 计算 ECFP6 4096bit ----------
def calculate_descriptors(smiles):
    """ECFP6, 4096bit"""
    if not isinstance(smiles, str) or not smiles.strip():
        return {f'F{i}': None for i in range(4096)}
    mol = Chem.MolFromSmiles(smiles.strip())
    if mol is None:
        return {f'F{i}': None for i in range(4096)}
    fp = AllChem.GetMorganFingerprintAsBitVect(mol, radius=3, nBits=4096)
    arr = np.asarray(fp, dtype=np.uint8)
    return {f'F{i}': int(arr[i]) for i in range(4096)}



# 1. 数据加载与预处理
print("正在加载数据...")
df = pd.read_csv("/content/CHEMBL2903_.csv")

# 2. 计算分子描述符
print("正在计算分子描述符...")
descriptors = df['Smiles'].apply(calculate_descriptors)
df = pd.concat([df, descriptors.apply(pd.Series)], axis=1)

# 3. 数据清洗
print("\n数据清洗：")
initial_count = len(df)
df = df.dropna(subset=descriptors.apply(pd.Series).columns)
print(f"删除无效SMILES记录：{initial_count - len(df)}条")

# 处理其他缺失值
numeric_cols = df.select_dtypes(include=np.number).columns
df[numeric_cols] = df[numeric_cols].fillna(df[numeric_cols].mean())

# 4. 准备特征矩阵和标签
X = df.drop(['Smiles', 'PIC50'], axis=1)
y = df['PIC50']

# 检查特征矩阵数据类型
if not all([np.issubdtype(dtype, np.number) for dtype in X.dtypes]):
    raise ValueError("特征矩阵包含非数值型列")

# 5. 特征选择
print("\n特征选择：")
threshold = 0.8 * (1 - 0.8)
selection = VarianceThreshold(threshold=threshold)
X_selected = selection.fit_transform(X)
selected_features = X.columns[selection.get_support(indices=True)]
X = pd.DataFrame(X_selected, columns=selected_features)
print(f"保留特征数量：{X.shape[1]}")

# 6. 拆分数据集
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42
)
print(f"\n训练集大小：{X_train.shape[0]} 样本")
print(f"测试集大小：{X_test.shape[0]} 样本")

# 7. 定义Optuna目标函数（改为RandomForest参数）
def objective(trial):
    params = {
        'n_estimators': trial.suggest_int('n_estimators', 100, 1000),
        'max_depth': trial.suggest_int('max_depth', 5, 50),
        'min_samples_split': trial.suggest_int('min_samples_split', 2, 20),
        'min_samples_leaf': trial.suggest_int('min_samples_leaf', 1, 10),
        'max_features': trial.suggest_categorical('max_features', ['sqrt', 'log2', 0.3, 0.5, 0.7, None]),
        'bootstrap': trial.suggest_categorical('bootstrap', [True, False]),
        'random_state': 42,
        'n_jobs': -1
    }

    model = RandomForestRegressor(**params)  # 改为RandomForest
    kf = KFold(n_splits=5, shuffle=True, random_state=42)
    score = cross_val_score(model, X_train, y_train, cv=kf,
                          scoring='neg_mean_squared_error', n_jobs=-1).mean()
    return score

# 8. 运行Optuna优化
print("\n开始超参数优化...")
study = optuna.create_study(direction='maximize')
study.optimize(objective, n_trials=50, show_progress_bar=True)

print("\n最佳参数:")
print(study.best_params)
print(f"最佳分数 (负MSE): {study.best_value:.4f}")

# 9. 提取试验结果并预处理
trials_df = study.trials_dataframe()
trials_df['RMSE'] = np.sqrt(-trials_df['value'])
trials_df = trials_df.rename(columns=lambda x: x.replace('params_', ''))

# 保存优化结果
trials_df.to_csv('optuna_optimization_results.csv', index=False)
print("\n优化结果已保存为 optuna_optimization_results.csv")

# 10. 绘制单参数与RMSE关系图（改为RF参数）
plt.figure(figsize=(6, 6),dpi=300)
params_to_plot = ['n_estimators', 'max_depth', 'min_samples_split', 'min_samples_leaf']

for i, param in enumerate(params_to_plot, 1):
    ax = plt.subplot(2, 2, i)

    sc = ax.scatter(trials_df[param], trials_df['RMSE'],
                   color=colors['dark_blue'],
                   alpha=0.7)

    best_idx = trials_df['RMSE'].idxmin()
    ax.scatter(trials_df.loc[best_idx, param], trials_df.loc[best_idx, 'RMSE'],
              color=colors['red'], marker='*', s=200, label='Best')

    ax.set_xlabel(param, fontsize=12)
    ax.set_ylabel('RMSE', fontsize=12)
    ax.set_title(f'{param} vs RMSE', fontsize=14)
    ax.grid(True, linestyle=':', alpha=0.6)

    if i == 1:
        ax.legend()

plt.tight_layout()
plt.savefig('hyperparameter_rmse_relationship.png', dpi=300, bbox_inches='tight')
plt.show()

# 11. 绘制参数重要性图（6×6，dpi=300）
plt.figure(figsize=(6, 6), dpi=300, facecolor='white')
param_importance = optuna.importance.get_param_importances(study)
param_names = list(param_importance.keys())
importance_values = list(param_importance.values())

# 限制颜色数量，循环使用
color_list = [colors['light_blue'], colors['blue'], colors['dark_blue'],
              colors['orange'], colors['yellow'], colors['red']]

# 为每个柱子分配颜色
bar_colors = [color_list[i % len(color_list)] for i in range(len(param_names))]

bars = plt.barh(param_names, importance_values, color=bar_colors,
                edgecolor='black', linewidth=1.2)
plt.xlabel('Importance', fontsize=12)
plt.ylabel('Parameters', fontsize=12)
plt.title('Hyperparameter Importance', fontsize=14, pad=15)
plt.grid(True, axis='x', linestyle=':', alpha=0.6)
plt.gca().invert_yaxis()

# 在柱子上标注数值
for bar, val in zip(bars, importance_values):
    plt.text(val + 0.01, bar.get_y() + bar.get_height()/2,
             f'{val:.3f}', va='center', fontsize=9)

plt.tight_layout()
plt.savefig('hyperparameter_importance.png', dpi=300, bbox_inches='tight')
plt.show()

# 12. 使用最佳参数训练最终模型
print("\n使用最佳参数训练最终模型...")
best_params = study.best_params
final_model = RandomForestRegressor(**best_params)
final_model.fit(X_train, y_train)

# 13. 测试集评估
y_pred = final_model.predict(X_test)
rmse = np.sqrt(mean_squared_error(y_test, y_pred))
r2 = r2_score(y_test, y_pred)

print(f"\n测试集性能评估：")
print(f"RMSE: {rmse:.4f}")
