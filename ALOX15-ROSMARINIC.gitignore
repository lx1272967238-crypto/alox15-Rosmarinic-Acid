# 14. 绘制测试集预测结果（6×6，dpi=300）
plt.figure(figsize=(6, 6), dpi=300, facecolor='white')
sns.set_style("whitegrid")

slope, intercept, r_value, _, _ = linregress(y_test, y_pred)
reg_line = slope * y_test + intercept

# 散点图
plt.scatter(y_test, y_pred,
            alpha=0.7,
            color=colors['blue'],
            edgecolor='black',
            linewidth=0.3,
            s=60,
            label='Predictions')

# 回归线
plt.plot(y_test, reg_line,
         color=colors['red'],
         linewidth=2.5,
         label=f'Regression')

# 完美拟合线
plt.plot([y_test.min(), y_test.max()],
         [y_test.min(), y_test.max()],
         '--',
         color=colors['dark_blue'],
         linewidth=2,
         label='Perfect fit')

plt.xlabel('True PIC50 Values', fontsize=12, labelpad=10)
plt.ylabel('Predicted PIC50 Values', fontsize=12, labelpad=10)
plt.title(f'Test Set Predictions',
          fontsize=13, pad=15)
plt.legend(fontsize=9, loc='lower right')

# 指标文本框
textstr = f'R² = {r2:.4f}\nRMSE = {rmse:.4f}'
plt.text(0.05, 0.95,
         textstr,
         transform=plt.gca().transAxes,
         fontsize=10,
         verticalalignment='top',
         bbox=dict(facecolor='white', alpha=0.9, edgecolor='gray', boxstyle='round,pad=0.5'))

plt.grid(True, linestyle=':', alpha=0.7)
plt.tight_layout()
plt.savefig('test_set_predictions.png', dpi=300, bbox_inches='tight')
plt.show()

# 15. 绘制特征重要性图（6×6，dpi=300）
plt.figure(figsize=(6, 6), dpi=300, facecolor='white')
feature_importance = pd.DataFrame({
    'feature': X.columns,
    'importance': final_model.feature_importances_
}).sort_values('importance', ascending=True).tail(15)  # Top 15

# 渐变色
n_features = len(feature_importance)
bar_colors = plt.cm.Blues(np.linspace(0.4, 0.9, n_features))

bars = plt.barh(feature_importance['feature'],
                feature_importance['importance'],
                color=bar_colors,
                edgecolor='black',
                linewidth=1.2)

plt.xlabel('Importance', fontsize=12)
plt.ylabel('Features', fontsize=12)
plt.title('Random Forest Feature Importance (Top 15)', fontsize=13, pad=15)
plt.grid(True, axis='x', linestyle=':', alpha=0.6)

# 在柱子上标注数值
for bar, val in zip(bars, feature_importance['importance']):
    plt.text(val + 0.005, bar.get_y() + bar.get_height()/2,
             f'{val:.3f}', va='center', fontsize=8)

plt.tight_layout()
plt.savefig('feature_importance.png', dpi=300, bbox_inches='tight')
plt.show()

# 16. 保存模型和结果
print("\n保存模型和结果...")
joblib.dump(final_model, 'optimized_rf_model.pkl')

preprocessing_info = {
    'feature_columns': X.columns.tolist(),
    'variance_selector': selection,
    'numeric_means': df[numeric_cols].mean().to_dict()
}
joblib.dump(preprocessing_info, 'preprocessing_info.pkl')

# 保存性能摘要
summary_data = {
    'Best_RMSE': [np.sqrt(-study.best_value)],
    'Best_R2': [r2],
    'Best_Params': [str(study.best_params)],
    'Test_RMSE': [rmse],
    'Test_R2': [r2]
}
