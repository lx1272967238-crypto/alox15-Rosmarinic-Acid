import pandas as pd
import numpy as np
import joblib
from rdkit import Chem
from rdkit.Chem import Descriptors
from sklearn.model_selection import train_test_split, KFold
from sklearn.feature_selection import VarianceThreshold
from sklearn.metrics import mean_squared_error, r2_score, mean_absolute_error
import matplotlib.pyplot as plt
import seaborn as sns
from lightgbm import LGBMRegressor, early_stopping
from scipy.stats import linregress
from rdkit.Chem import AllChem
import warnings
warnings.filterwarnings('ignore')

# ---------- 1. 计算 ECFP6 4096bit ----------
def calculate_descriptors(smiles):
    """ECFP6, 4096bit"""
    if not isinstance(smiles, str) or not smiles.strip():
        return {f'F{i}': None for i in range(4096)}
    mol = Chem.MolFromSmiles(smiles.strip())
    if mol is None:
        return {f'F{i}': None for i in range(4096)}
    fp = AllChem.GetMorganFingerprintAsBitVect(mol, radius=3, nBits=4096)
    arr = np.asarray(fp, dtype=np.uint8)
    return {f'F{i}': int(arr[i]) for i in range(4096)}



# 1. 数据加载与预处理
print("正在加载数据...")
df = pd.read_csv("/content/CHEMBL2903_.csv")

# 2. 计算分子描述符
print("正在计算分子描述符...")
descriptors = df['Smiles'].apply(calculate_descriptors)
df = pd.concat([df, descriptors.apply(pd.Series)], axis=1)

# 3. 数据清洗
print("\n数据清洗：")
initial_count = len(df)
df = df.dropna(subset=descriptors.apply(pd.Series).columns)
print(f"删除无效SMILES记录：{initial_count - len(df)}条")

# 处理其他缺失值
numeric_cols = df.select_dtypes(include=np.number).columns
df[numeric_cols] = df[numeric_cols].fillna(df[numeric_cols].mean())

# 4. 准备特征矩阵和标签
X = df.drop(['Smiles', 'PIC50'], axis=1)
y = df['PIC50']

# 检查特征矩阵数据类型
if not all([np.issubdtype(dtype, np.number) for dtype in X.dtypes]):
    raise ValueError("特征矩阵包含非数值型列")

# 5. 特征选择
print("\n特征选择：")
threshold = 0.8 * (1 - 0.8)
selection = VarianceThreshold(threshold=threshold)
X_selected = selection.fit_transform(X)
selected_features = X.columns[selection.get_support(indices=True)]
X = pd.DataFrame(X_selected, columns=selected_features)
print(f"保留特征数量：{X.shape[1]}")

# 6. 拆分数据集
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3, random_state=42
)
print(f"\n训练集大小：{X_train.shape[0]} 样本")
print(f"测试集大小：{X_test.shape[0]} 样本")

# 7. K折交叉验证设置
n_folds = 5
kf = KFold(n_splits=n_folds, shuffle=True, random_state=42)
cv_results = {'train_mse': [], 'val_mse': [], 'val_r2': [], 'val_mae': []}
fold_predictions = []

# 8. 进行K折交叉验证
print(f"\n进行{n_folds}折交叉验证...")
for fold, (train_idx, val_idx) in enumerate(kf.split(X_train), 1):
    print(f"\nFold {fold}/{n_folds}")
    X_tr, X_val = X_train.iloc[train_idx], X_train.iloc[val_idx]
    y_tr, y_val = y_train.iloc[train_idx], y_train.iloc[val_idx]

    # 改为随机森林（无 learning_rate 和 early_stopping）
    model = RandomForestRegressor(
        n_estimators=500,        # 树的数量（RF 没有 early_stopping，用适中值）
        max_depth=20,            # 最大深度，防止过拟合
        min_samples_split=5,     # 节点分裂最小样本数
        min_samples_leaf=2,      # 叶子节点最小样本数
        max_features='sqrt',     # 每次分裂考虑的特征数
        random_state=42,
        n_jobs=-1                # 使用所有CPU核心
    )

    # RF 直接 fit，无需 eval_set 和 early_stopping
    model.fit(X_tr, y_tr)

    # 记录结果
    train_pred = model.predict(X_tr)
    val_pred = model.predict(X_val)

    cv_results['train_mse'].append(mean_squared_error(y_tr, train_pred))
    cv_results['val_mse'].append(mean_squared_error(y_val, val_pred))
    cv_results['val_r2'].append(r2_score(y_val, val_pred))
    cv_results['val_mae'].append(mean_absolute_error(y_val, val_pred))

    fold_predictions.append((y_val, val_pred))

    print(f"  Train MSE: {cv_results['train_mse'][-1]:.4f}")
    print(f"  Val MSE: {cv_results['val_mse'][-1]:.4f}")
    print(f"  Val R²: {cv_results['val_r2'][-1]:.4f}")
    print(f"  Val MAE: {cv_results['val_mae'][-1]:.4f}")

# 定义颜色方案
colors = {
    'red': (219/255, 49/255, 36/255),
    'orange': (252/255, 140/255, 90/255),
    'yellow': (255/255, 223/255, 146/255),
    'light_blue': (230/255, 241/255, 243/255),
    'blue': (144/255, 190/255, 224/255),
    'dark_blue': (75/255, 116/255, 178/255)
}

# 9. 绘制K折验证结果（拆分为4个独立图，每个6×6，dpi=300）

# 图1: 各折MSE对比
plt.figure(figsize=(6, 6), dpi=300, facecolor='white')
plt.plot(range(1, n_folds+1), cv_results['train_mse'], 'o-',
         color=colors['dark_blue'], label='Train MSE', linewidth=2, markersize=8)
plt.plot(range(1, n_folds+1), cv_results['val_mse'], 'o-',
         color=colors['red'], label='Val MSE', linewidth=2, markersize=8)
plt.xlabel('Fold', fontsize=11)
plt.ylabel('MSE', fontsize=11)
plt.title('Training and Validation MSE per Fold', fontsize=12, pad=15)
plt.legend(fontsize=10)
plt.grid(True, linestyle=':', alpha=0.7)
plt.tight_layout()
plt.savefig('fig1_mse_per_fold.png', dpi=300, bbox_inches='tight')
plt.show()

# 图2: 各折R²对比
plt.figure(figsize=(6, 6), dpi=300, facecolor='white')
bars = plt.bar(range(1, n_folds+1), cv_results['val_r2'],
               color=colors['blue'], edgecolor='black', linewidth=1.2)
plt.xlabel('Fold', fontsize=11)
plt.ylabel('R² Score', fontsize=11)
plt.title('Validation R² per Fold', fontsize=12, pad=15)
plt.ylim(0, 1)
plt.grid(True, linestyle=':', alpha=0.7, axis='y')
# 在柱子上标注数值
for bar, val in zip(bars, cv_results['val_r2']):
    plt.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.02,
             f'{val:.3f}', ha='center', va='bottom', fontsize=9)
plt.tight_layout()
plt.savefig('fig2_r2_per_fold.png', dpi=300, bbox_inches='tight')
plt.show()

# 图3: 预测结果散点图
plt.figure(figsize=(6, 6), dpi=300, facecolor='white')
fold_colors = [colors['dark_blue'], colors['red'], colors['orange'],
               colors['yellow'], colors['blue']]
for i, (y_val, pred) in enumerate(fold_predictions, 1):
    plt.scatter(y_val, pred, alpha=0.6, color=fold_colors[i-1],
                label=f'Fold {i}', edgecolor='w', linewidth=0.3, s=50)
min_val = min([min(y) for y, _ in fold_predictions])
max_val = max([max(y) for y, _ in fold_predictions])
plt.plot([min_val, max_val], [min_val, max_val], 'k--', linewidth=2, label='Perfect fit')
plt.xlabel('True PIC50 Values', fontsize=11)
plt.ylabel('Predicted PIC50 Values', fontsize=11)
plt.title('Prediction Results by Fold', fontsize=12, pad=15)
plt.legend(fontsize=9, loc='lower right')
plt.grid(True, linestyle=':', alpha=0.7)
plt.tight_layout()
plt.savefig('fig3_prediction_scatter.png', dpi=300, bbox_inches='tight')
plt.show()

# 图4: 误差分布
plt.figure(figsize=(6, 6), dpi=300, facecolor='white')
errors = np.concatenate([y - pred for y, pred in fold_predictions])
sns.histplot(errors, kde=True, bins=20, color=colors['blue'], edgecolor='black')
plt.axvline(x=0, color=colors['red'], linestyle='--', linewidth=2, label='Zero error')
plt.xlabel('Prediction Error', fontsize=11)
plt.ylabel('Frequency', fontsize=11)
plt.title('Error Distribution Across Folds', fontsize=12, pad=15)
plt.legend(fontsize=10)
plt.grid(True, linestyle=':', alpha=0.7)
plt.tight_layout()
plt.savefig('fig4_error_distribution.png', dpi=300, bbox_inches='tight')
plt.show()

# 10. 训练最终模型并评估测试集
print("\n训练最终模型并评估测试集...")

final_model = RandomForestRegressor(
    n_estimators=500,
    max_depth=20,
    min_samples_split=5,
    min_samples_leaf=2,
    max_features='sqrt',
    random_state=42,
    n_jobs=-1
)

final_model.fit(X_train, y_train)

# 11. 测试集评估
y_pred = final_model.predict(X_test)

metrics = {
    'MSE': mean_squared_error(y_test, y_pred),
    'R²': r2_score(y_test, y_pred),
    'MAE': mean_absolute_error(y_test, y_pred)
}

print("\n测试集性能指标:")
print(f"MSE: {metrics['MSE']:.4f}")
print(f"R²: {metrics['R²']:.4f}")
print(f"MAE: {metrics['MAE']:.4f}")

# 12. 绘制测试集结果（拆分为2个独立图，每个6×6，dpi=300）

# 图5: 测试集预测结果散点图
plt.figure(figsize=(6, 6), dpi=300, facecolor='white')
plt.scatter(y_test, y_pred, alpha=0.7, color=colors['dark_blue'],
            edgecolor='w', linewidth=0.3, s=60)
min_val, max_val = min(y_test.min(), y_pred.min()), max(y_test.max(), y_pred.max())
buffer = (max_val - min_val) * 0.05
plt.plot([min_val, max_val], [min_val, max_val], 'k--', linewidth=2, label='Perfect fit')

# 添加回归线
slope, intercept, r_value, _, _ = linregress(y_test, y_pred)
reg_line = slope * y_test + intercept
plt.plot(y_test, reg_line, color=colors['red'], linewidth=2,
         label=f'Regression (R²={metrics["R²"]:.3f})')

plt.xlabel('True PIC50 Values', fontsize=11)
plt.ylabel('Predicted PIC50 Values', fontsize=11)
plt.title('Test Set Predictions', fontsize=12, pad=15)
plt.legend(fontsize=10, loc='lower right')
plt.grid(True, linestyle=':', alpha=0.7)

# 添加指标文本框
textstr = f'R² = {metrics["R²"]:.4f}\nRMSE = {np.sqrt(metrics["MSE"]):.4f}\nMAE = {metrics["MAE"]:.4f}'
plt.text(0.05, 0.95, textstr, transform=plt.gca().transAxes,
         fontsize=10, verticalalignment='top',
         bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.8))

plt.xlim(min_val - buffer, max_val + buffer)
plt.ylim(min_val - buffer, max_val + buffer)
plt.tight_layout()
plt.savefig('fig5_test_prediction.png', dpi=300, bbox_inches='tight')
plt.show()

# 图6: 测试集误差分布
plt.figure(figsize=(6, 6), dpi=300, facecolor='white')
test_errors = y_test - y_pred
sns.histplot(test_errors, kde=True, bins=20, color=colors['blue'],
             edgecolor='black', linewidth=1.2)
plt.axvline(x=0, color=colors['red'], linestyle='--', linewidth=2, label='Zero error')
plt.axvline(x=test_errors.mean(), color='green', linestyle='--',
            linewidth=2, label=f'Mean error ({test_errors.mean():.3f})')
plt.xlabel('Prediction Error', fontsize=11)
plt.ylabel('Frequency', fontsize=11)
plt.title('Test Set Error Distribution', fontsize=12, pad=15)
plt.legend(fontsize=10)
plt.grid(True, linestyle=':', alpha=0.7)
plt.tight_layout()
plt.savefig('fig6_test_error_distribution.png', dpi=300, bbox_inches='tight')
plt.show()

# 13. 保存模型
joblib.dump(final_model, 'rf_model.pkl')
print("\n模型已保存为 'rf_model.pkl'")

# 14. 输出特征重要性（RF 特有）
feature_importance = pd.DataFrame({
    'feature': X.columns,
    'importance': final_model.feature_importances_
}).sort_values('importance', ascending=False)

print("\nTop 10 重要特征:")
print(feature_importance.head(10))

# 图7: 特征重要性（可选，也是6×6）
plt.figure(figsize=(6, 6), dpi=300, facecolor='white')
top_features = feature_importance.head(15)
plt.barh(range(len(top_features)), top_features['importance'],
         color=colors['dark_blue'], edgecolor='black', linewidth=1.2)
plt.yticks(range(len(top_features)), top_features['feature'], fontsize=9)
plt.xlabel('Importance', fontsize=11)
plt.ylabel('Features', fontsize=11)
plt.title('Top 15 Feature Importances', fontsize=12, pad=15)
plt.gca().invert_yaxis()
plt.grid(True, axis='x', linestyle=':', alpha=0.7)
plt.tight_layout()
plt.savefig('fig7_feature_importance.png', dpi=300, bbox_inches='tight')
plt.show()
